generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  children Child[]
}

model Child {
  id            String   @id @default(uuid())
  name          String
  dateOfBirth   DateTime
  learningLevel String   @default("BEGINNER")
  interests     String   @default("")
  strengths     String   @default("")
  weaknesses    String   @default("")
  notes         String   @default("")

  parentId String
  parent   User   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  assessments        Assessment[]
  mazeExercises      MazeExercise[]
  mandalaExercises   MandalaExercise[]
  rightBrainExercises RightBrainExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Assessment {
  id            String   @id @default(uuid())
  childId       String
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  sectionScores String   // JSON: { A: { total: 42, questions: [3,5,4,...] }, B: {...}, ... }
  interests     String   // JSON array of checked interest items
  archetypes    String   // JSON: computed archetype matches from scoring
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([childId])
}

model ErrorLog {
  id        String   @id @default(uuid())
  level     String   @default("error") // error, warn, info
  message   String
  source    String   @default("client") // client, api, server
  url       String   @default("")
  userId    String?
  stack     String?  // Stack trace or extra details
  metadata  String?  // JSON: additional context
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}

model MazeExercise {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  difficulty  String   @default("easy")
  maze        String   // JSON: { rows, cols, grid, start, end }
  completed   Boolean  @default(false)
  score       Int?
  timeSpent   Int?     // seconds
  steps       Int?     // number of moves taken
  createdAt   DateTime @default(now())

  @@index([childId])
}

model MandalaExercise {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  difficulty  String   @default("easy")
  pattern     String   // JSON: { symmetry, slices, palette }
  completed   Boolean  @default(false)
  score       Int?
  timeSpent   Int?     // seconds
  recallCount Int?     // how many colors they recalled correctly
  createdAt   DateTime @default(now())

  @@index([childId])
}

model RightBrainExercise {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  category    String   // spatial-rotation, pattern-completion, visual-memory, odd-one-out, mirror-image
  difficulty  String   @default("easy")
  data        String   // JSON: exercise-specific data
  completed   Boolean  @default(false)
  score       Int?
  timeSpent   Int?     // seconds
  createdAt   DateTime @default(now())

  @@index([childId])
}
